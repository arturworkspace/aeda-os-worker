# mongodb atlas connection string (shared with aeda workspace)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/aeda?retryWrites=true&w=majority

# anthropic api key for llm calls
ANTHROPIC_API_KEY=sk-ant-...

# cloudflare r2 credentials (s3-compatible)
R2_ENDPOINT=https://accountid.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=aeda-backups

# optional: log level (default: info)
LOG_LEVEL=info
